{
  "name": "movies",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ref:home:sync": "node -e \"fetch('http://127.0.0.1:3000/api/reference/home?refresh=1').then(r=>r.text()).then(()=>console.log('OK')).catch(e=>{console.error(e);process.exit(1)})\"",
    "home:snapshot:update": "node scripts/update-home-snapshot.js",
    "daily:sync": "node scripts/daily-sync.js",
    "sync:recent": "node scripts/daily-sync.js --recent --pages=6 --batch=5",
    "sync:recent:watch": "node scripts/daily-sync.js --recent --pages=6 --batch=5 --watch=1440",
    "sync:daily:check": "node scripts/daily-sync.js --recent --pages=6 --batch=5",
    "dev": "next dev --turbopack",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.0",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
